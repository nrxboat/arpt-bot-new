# ============================================
# ARPT-Bot 环境变量配置
# 复制此文件为 .env 并填入真实值
# ============================================

# ---------- Telegram API（在 https://my.telegram.org 申请）----------
API_ID=12345678
API_HASH=your_api_hash_here

# ---------- Telegram Bot ----------
# 在 @BotFather 申请
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# ---------- 授权用户 / 群组 ----------
# 单个用户 ID（从 @userinfobot 获取）或群组 ID（负值，如 -1001234567890）
OWNER_ID=123456789

# ---------- Aria2 ----------
ARIA2_SECRET=your_aria2_secret_here
# AriaNg Web 面板端口（默认 8080）
ARIA2_WEB_PORT=8080

# ---------- Rclone ----------
# rclone 远程盘符，例如 gd、onedrive、ali
RCLONE_REMOTE=your_remote_name
# 上传目标文件夹（不加尾斜杠）
RCLONE_UPLOAD_DIR=ARPT-Bot
# 上传完成后是否返回分享链接（仅 OneDrive 有效）
RCLONE_SHARE=false

# ---------- 不授权用户提示（可选）----------
ERROR_USER_INFO=你没有使用权限，请联系管理员。
