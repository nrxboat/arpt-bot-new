# ARPT-Bot 鐜鍙橀噺閰嶇疆
# 澶嶅埗姝ゆ枃浠朵负 .env 骞跺～鍏ョ湡瀹炲€?# ============================================

# ---------- Telegram API锛堝湪 https://my.telegram.org 鐢宠锛?---------
API_ID=12345678
API_HASH=your_api_hash_here

# ---------- Telegram Bot ----------
# 鍦?@BotFather 鐢宠
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# ---------- 鎺堟潈鐢ㄦ埛 / 缇ょ粍 ----------
# 鍗曚釜鐢ㄦ埛 ID锛堜粠 @userinfobot 鑾峰彇锛夋垨缇ょ粍 ID锛堣礋鍊硷紝濡?-1001234567890锛?OWNER_ID=123456789

# ---------- Aria2 ----------
ARIA2_SECRET=your_aria2_secret_here
# AriaNg Web 闈㈡澘绔彛锛堥粯璁?8080锛?ARIA2_WEB_PORT=8080

# ---------- Rclone ----------
# rclone 杩滅▼鐩樼锛屼緥濡?gd銆乷nedrive銆乤li
RCLONE_REMOTE=your_remote_name
# 涓婁紶鐩爣鏂囦欢澶癸紙涓嶅姞灏炬枩鏉狅級
RCLONE_UPLOAD_DIR=ARPT-Bot
# 涓婁紶瀹屾垚鍚庢槸鍚﹁繑鍥炲垎浜摼鎺ワ紙浠?OneDrive 鏈夋晥锛?RCLONE_SHARE=false

# ---------- Pixiv ----------
# 浼樺厛锛氱洿鎺ュ～鍐?refresh_token
PIXIV_REFRESH_TOKEN=
# 鎴栵細濉啓璐﹀彿瀵嗙爜锛堣嚜鍔ㄩ€氳繃 pixiv-token 鑾峰彇 refresh_token锛?PIXIV_USERNAME=
PIXIV_PASSWORD=

# ---------- 涓嶆巿鏉冪敤鎴锋彁绀猴紙鍙€夛級----------
ERROR_USER_INFO=浣犳病鏈変娇鐢ㄦ潈闄愶紝璇疯仈绯荤鐞嗗憳銆